{
  "name": "KAI OS",
  "image": "mcr.microsoft.com/devcontainers/java:1-17-bookworm",
  "customizations": {
    "vscode": {
      "extensions": [
        "fwcd.kotlin",
        "vscjava.vscode-gradle"
      ]
    }
  },
  "postCreateCommand": "./gradlew :kaios-cli:installDist --no-daemon",
  "postAttachCommand": "echo 'KAI OS ready. Try: build/install/kaios-cli/bin/kaios tour'",
  "remoteEnv": {
    "KAIOS_RUNS_DIR": "${containerWorkspaceFolder}/.kaios/runs",
    "KAIOS_ARTIFACTS_DIR": "${containerWorkspaceFolder}/artifacts"
  }
}
